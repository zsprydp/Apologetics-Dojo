# Supabase (required for auth and database)
# Get these from: Project Settings → API in Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase service role key (server-only; never expose to client)
# Required only for scripts that create test users: npm run seed:users
# Dashboard → Project Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key (required for AI debate opponents)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
