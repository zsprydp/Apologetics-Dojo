# Supabase (required for auth and database)
# Get these from: Project Settings → API in Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase service role key (server-only; never expose to client)
# Required only for scripts that create test users: npm run seed:users
# Dashboard → Project Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key (required for AI debate opponents)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Resend (optional — enables welcome emails and weekly digest)
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=re_...
# EMAIL_FROM=Apologetics Dojo <noreply@yourdomain.com>

# Cron secret (protects the /api/cron/* endpoints)
# Generate a random string and set it in both your env and your cron service
# CRON_SECRET=your-random-cron-secret

# Site URL (used in email templates for links)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# PostHog analytics (optional)
# Get from: https://posthog.com → Project Settings
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe (optional — enables Pro plan billing)
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
